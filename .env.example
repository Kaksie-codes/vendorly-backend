# ─────────────────────────────────────────────────────────────
# .env.example
# Copy this file to .env and fill in your own values.
# Never commit your real .env file to git.
# ─────────────────────────────────────────────────────────────


# ── SERVER ───────────────────────────────────────────────────
# "development" or "production"
NODE_ENV=development

# Port the API server will listen on
PORT=5000


# ── MONGODB ──────────────────────────────────────────────────
# Your MongoDB Atlas connection string.
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>
MONGO_URL=mongodb+srv://username:password@cluster.mongodb.net/vendorly


# ── JWT (Authentication) ─────────────────────────────────────
# A long random string used to sign and verify JWT tokens.
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_very_long_random_secret_here

# How long a JWT token stays valid before the user must log in again
JWT_EXPIRES_IN=30d


# ── AWS S3 (File Uploads) ────────────────────────────────────
# Used to store product images and vendor documents.
# Create a bucket and IAM user in your AWS console.
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_REGION=eu-west-1
AWS_BUCKET_NAME=vendorly-uploads


# ── ANTHROPIC AI ─────────────────────────────────────────────
# Used for AI-powered features like product description generation.
# Get your key from: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your_key_here


# ── EMAIL ────────────────────────────────────────────────────
# Used to send verification emails, password resets, etc.
# This project uses Resend — get a key from: https://resend.com
RESEND_API_KEY=re_your_key_here
EMAIL_FROM=noreply@yourdomain.com


# ── FRONTEND ─────────────────────────────────────────────────
# The URL of your frontend app.
# Used for CORS (allowing the frontend to call this API)
# and for building links inside emails (e.g. password reset links).
CLIENT_URL=http://localhost:3000

# The public URL of this API server.
# Used to build the OAuth callback URLs sent to each provider.
# In development: http://localhost:5000
# In production:  https://api.yourdomain.com
API_URL=http://localhost:5000


# ── OAUTH PROVIDERS ──────────────────────────────────────────
# Register your app with each provider to get these credentials.
# Each provider requires you to whitelist the callback URL:
#   {API_URL}/api/auth/{provider}/callback

# Google — https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# GitHub — https://github.com/settings/developers → OAuth Apps
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
