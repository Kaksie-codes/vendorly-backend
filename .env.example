# ─────────────────────────────────────────────────────────────
# .env.example
# Copy this file to .env and fill in your own values.
# Never commit your real .env file to git.
# ─────────────────────────────────────────────────────────────


# ── SERVER ───────────────────────────────────────────────────
# "development" or "production"
NODE_ENV=development

# Port the API server will listen on
PORT=5000


# ── MONGODB ──────────────────────────────────────────────────
# Your MongoDB Atlas connection string.
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>
MONGO_URL=mongodb+srv://username:password@cluster.mongodb.net/vendorly


# ── JWT (Authentication) ─────────────────────────────────────
# A long random string used to sign and verify JWT tokens.
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_very_long_random_secret_here

# How long a JWT token stays valid before the user must log in again
JWT_EXPIRES_IN=30d


# ── AWS S3 (File Uploads) ────────────────────────────────────
# Used to store product images and vendor documents.
# Create a bucket and IAM user in your AWS console.
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_REGION=eu-west-1
AWS_BUCKET_NAME=vendorly-uploads


# ── ANTHROPIC AI ─────────────────────────────────────────────
# Used for AI-powered features like product description generation.
# Get your key from: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your_key_here


# ── EMAIL ────────────────────────────────────────────────────
# Used to send order confirmations, password resets, etc.
# This project uses SendGrid — get a key from: https://sendgrid.com
EMAIL_FROM=noreply@vendorly.com
SENDGRID_API_KEY=SG.your_key_here


# ── FRONTEND ─────────────────────────────────────────────────
# The URL of your frontend app.
# Used for CORS (allowing the frontend to call this API)
# and for building links inside emails (e.g. password reset links).
CLIENT_URL=http://localhost:3000
